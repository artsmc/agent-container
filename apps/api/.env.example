# ---- Required ----
DATABASE_URL=postgresql://user:password@localhost:5432/iexcel
AUTH_ISSUER_URL=http://localhost:3100

# ---- Optional (defaults shown) ----
AUTH_AUDIENCE=iexcel-api
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=*

# ---- Workflow Orchestration (Feature 17) ----
# MASTRA_BASE_URL=http://localhost:4111  # Mastra runtime base URL
# MASTRA_CLIENT_ID=mastra-agent  # Mastra OIDC client_id
# API_BASE_URL=http://localhost:8080  # This API's public base URL (callback URL)
# WORKFLOW_TIMEOUT_MS=300000  # Workflow timeout (5 minutes default)
# ADMIN_OWNER=  # Admin user UUID for system-triggered runs

# ---- Grain Integration (Feature 37) ----
# GRAIN_API_KEY=<your-grain-api-key>  # Retrieved from secret manager in production
# GRAIN_API_BASE_URL=https://api.grain.com/v1  # Override for test environments
# GRAIN_ADAPTER_ENABLED=true  # Feature flag: set to 'true' to enable Grain submissions
