# Auth service OIDC issuer — server-side only (never exposed to the browser)
# Example: https://auth.iexcel.com
AUTH_ISSUER_URL=https://auth.example.com

# UI's own public URL — available in both the browser and the server
# No trailing slash. Used to construct the PKCE redirect_uri.
# Example: https://app.iexcel.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Product API base URL — server-side only
# Example: https://api.iexcel.com
API_BASE_URL=http://localhost:4000
