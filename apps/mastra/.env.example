# ── External Service URLs ────────────────────────────────────────────────────
# Base URL for the iExcel REST API (feature 14 / api app)
API_BASE_URL=http://localhost:3000

# OIDC issuer URL for the iExcel auth service (apps/auth)
AUTH_ISSUER_URL=http://localhost:4000

# ── Mastra Service Identity (client credentials grant) ───────────────────────
MASTRA_CLIENT_ID=mastra-service
MASTRA_CLIENT_SECRET=changeme

# ── LLM Configuration ────────────────────────────────────────────────────────
# Your LLM provider API key
LLM_API_KEY=sk-...

# Which provider to use: openai | anthropic
LLM_PROVIDER=anthropic

# Model identifier (provider-specific string routed via @mastra/core model router)
# Anthropic examples: claude-sonnet-4-20250514, claude-opus-4-5
# OpenAI examples:    gpt-4o, gpt-4o-mini
LLM_MODEL=claude-sonnet-4-20250514

# ── Mastra Server ────────────────────────────────────────────────────────────
MASTRA_PORT=8081
MASTRA_HOST=0.0.0.0

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Observability (optional) ─────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=iexcel-mastra
