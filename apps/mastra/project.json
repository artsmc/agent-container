{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "mastra",
  "projectType": "application",
  "root": "apps/mastra",
  "sourceRoot": "apps/mastra/src",
  "tags": ["scope:mastra", "type:app"],
  "implicitDependencies": ["api-client", "auth-client", "shared-types"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm mastra build",
        "cwd": "apps/mastra"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm mastra dev",
        "cwd": "apps/mastra"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/mastra/tsconfig.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config apps/mastra/vitest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/mastra/**/*.ts"]
      }
    }
  }
}
